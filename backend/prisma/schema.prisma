generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

enum MemberRole {
  ketua
  anggota

  @@schema("public")
}

model User {
  id         String    @id @default(uuid())
  first_name String
  last_name  String
  email      String    @unique
  password   String
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  @@map("users")
  @@schema("auth")
}

model activities {
  id            Int       @id @default(autoincrement())
  title         String
  description   String
  markdown_file String    @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime? @updatedAt

  @@map("activity")
  @@schema("public")
}

model member {
  id         Int        @id @default(autoincrement())
  name       String
  role       MemberRole
  message    String     @db.Text
  created_at DateTime   @default(now())
  updated_at DateTime?  @updatedAt

  @@map("membersRole")
  @@schema("public")
}
